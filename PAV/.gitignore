# uv / 가상환경
.venv/
# .python-version, uv.lock는 commit — 재현성 보존

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
*.egg-info/
build/
dist/

# 학습 산출물
outputs/
checkpoints/
wandb/
*.bin
*.safetensors
.hf_cache/

# Docker
.env
.envrc
*.local

# ZeroTier — (제거됨, FRP 로 대체) 옛 런타임 디렉토리 무시 — 안전성
zerotier/
ztncui/
nginx/
# FRP — 설정 .toml 은 commit (template, secret 은 env 로 inject). 런타임 산출물 무시
frp/*.log
# .example 파일은 commit (template)

