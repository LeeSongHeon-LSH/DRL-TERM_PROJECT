# 학습 PC (3090) — docker-compose.yml 용
# 사용:  cp .env.example .env  &&  vi .env

# HF 캐시 — 호스트에 영속화 (모델 다운로드 보존). 빈 칸이면 ./.hf_cache
HF_HOME_HOST=

# 옵션 — HF rate-limit 회피용
HF_TOKEN=

# trainer 전용 — wandb 로깅 (없으면 stdout만)
WANDB_API_KEY=

# ---- 분산 — 추론 PC IP/포트 (docker-compose.inference.yml이 8001 / 8002 listen) ----
# 같은 LAN의 추론 PC IP를 채우세요. PC 같으면 localhost.
PRM_ENDPOINT=http://192.168.1.10:8002
MU_ENDPOINT=http://192.168.1.10:8001
