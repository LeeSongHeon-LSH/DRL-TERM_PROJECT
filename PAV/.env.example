# docker compose 환경변수 템플릿. 사용:
#   cp .env.example .env  &&  vi .env
#
# === 분산 시 ===
# 브로커 PC: 그대로 두고 docker compose --profile broker up -d
# 다른 PC들: AMQP_URL을 broker PC의 IP로 설정
AMQP_URL=amqp://guest:guest@rabbitmq:5672/

# HF 캐시를 호스트와 공유 (모델 다운로드 영속화) — 빈 칸이면 ./.hf_cache 사용
HF_HOME_HOST=

# 옵션 — public 모델이라 토큰 없이도 가능하나 rate-limit 회피용 권장
HF_TOKEN=

# trainer 전용 — wandb 로깅
WANDB_API_KEY=
