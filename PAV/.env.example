# 공통 .env 템플릿 — 학습 PC + 추론 PC (모두 같은 파일 사용)
# 사용:  cp .env.example .env  &&  vi .env

# ============================================================
# 공통 설정
# ============================================================

# HF 캐시 — 호스트에 영속화 (모델 다운로드 보존). 빈 칸이면 ./.hf_cache
HF_HOME_HOST=

# 옵션 — HF rate-limit 회피용 (private token, .gitignore 필수)
HF_TOKEN=

# ============================================================
# FRP — TCP tunnel (학습 PC 공인 IP 활용, NAT 우회)
# ============================================================
# FRPS_TOKEN / FRPS_ADDR / NODE_NAME 은 .env 에 두지 않음 — 명령어 inline env (git 안전성):
#
#   학습 PC:
#     FRPS_TOKEN=<random-32+chars> docker compose up -d --build
#
#   추론 PC (NODE_NAME 만 각 PC 별로 unique):
#     FRPS_ADDR=<공인IP/DDNS> FRPS_TOKEN=<같은 토큰> NODE_NAME=5070-pc-01 \
#       docker compose -f docker-compose.inference.yml up -d --build
#
# 사전 작업 (학습 PC):
#   1. 라우터 포트포워딩 TCP 7000 → 학습 PC LAN IP (frpc 접속용)
#   2. 라우터 포트포워딩 TCP 18001~18099 → 학습 PC LAN IP (선택, 외부 모니터링용. 내부 통신만이면 불필요)
#   3. 방화벽: TCP 7000 inbound 허용
#
# FRP dashboard (모든 추론 PC 상태 실시간):
#   http://<학습PC>:7500   (admin / FRPS_DASHBOARD_PW)
FRPS_DASHBOARD_PW=changeme

# ============================================================
# 추론 PC (μ vLLM) — docker-compose.inference.yml
# ============================================================
# 1.5B 기준. 7B 로 가려면 MU_MODEL_ID 변경 + MU_GPU_MEM 0.65 로
MU_MODEL_ID=Qwen/Qwen2.5-Math-1.5B-Instruct
MU_GPU_MEM=0.85          # 24GB GPU → ~20 GB (μ 독점). 5070 12GB GPU 도 0.85
MU_MAX_LEN=1536          # prefix 1000 + completion 256 + 여유
MU_MAX_NUM_SEQS=32       # K=16 batch 에 여유

# ============================================================
# 학습 PC (trainer) — docker-compose.yml
# ============================================================

# trainer 전용 — wandb 로깅 (없으면 stdout 만)
WANDB_API_KEY=

# trainer 가 frps 의 18001/18002 로 호출 → frps 가 load balancer group 으로
# 살아있는 추론 PC mu/PRM replica 1개 round-robin (default, 단일 추론 PC 면 무관).
# 로컬 frps 컨테이너를 쓸 때는 아래 default 그대로 사용.
# 원격 FRPS host 를 쓸 때는 http://<FRPS_PUBLIC_IP_OR_DNS>:1800x 로 변경.
PRM_ENDPOINT=http://frps:18002
MU_ENDPOINT=http://frps:18001

# FRP dashboard URL (로컬 frps 컨테이너 또는 원격 FRPS host)
FRPS_DASHBOARD_URL=http://frps:7500
