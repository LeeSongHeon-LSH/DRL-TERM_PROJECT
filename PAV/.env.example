# 공통 .env 템플릿 — 학습 PC + 추론 PC (모두 같은 파일 사용)
# 사용:  cp .env.example .env  &&  vi .env

# ============================================================
# 공통 설정
# ============================================================

# HF 캐시 — 호스트에 영속화 (모델 다운로드 보존). 빈 칸이면 ./.hf_cache
HF_HOME_HOST=

# 옵션 — HF rate-limit 회피용 (private token, .gitignore 필수)
HF_TOKEN=

# ============================================================
# ZeroTier — mesh VPN (공인 IP 없이 학습 PC ↔ 추론 cluster 연결)
# ============================================================
# ZT_NETWORK_ID는 .env에 두지 않음 — 명령어 inline env로 전달 (git 안전성):
#
#   ZT_NETWORK_ID=bb3a80f571f32802 docker compose up -d
#
# ZTNCUI 자체 호스팅:
#   1. docker compose up -d ztncui   (ZT_NETWORK_ID 없어도 ztncui만은 시작됨)
#   2. http://localhost:3000 → admin / ZTNCUI_PASSWD (첫 접속 시 변경)
#   3. Networks → Add Network → 16자리 ID 발급 → 다음 명령어에 inline 전달
ZTNCUI_PASSWD=changeme

# ============================================================
# 추론 PC (μ vLLM) — docker-compose.inference.yml
# ============================================================
# 1.5B 기준. 7B로 가려면 MU_MODEL_ID 변경 + MU_GPU_MEM 0.65로
MU_MODEL_ID=Qwen/Qwen2.5-Math-1.5B-Instruct
MU_GPU_MEM=0.85          # 24GB GPU → ~20 GB (μ 독점). 5070 12GB GPU도 0.85
MU_MAX_LEN=1536          # prefix 1000 + completion 256 + 여유
MU_MAX_NUM_SEQS=32       # K=16 batch에 여유

# ============================================================
# 학습 PC (trainer) — docker-compose.yml
# ============================================================

# trainer 전용 — wandb 로깅 (없으면 stdout만)
WANDB_API_KEY=

# nginx-lb가 ZeroTier cluster로 분산. trainer는 localhost:18001/18002 호출.
# (분산 사용 안 하고 단일 추론 endpoint면 직접 IP 적어도 됨)
PRM_ENDPOINT=http://localhost:18002
MU_ENDPOINT=http://localhost:18001
