# 추론 PC (3090 Ti) — docker-compose.inference.yml 용
# 사용:  cp .env.inference.example .env  &&  vi .env

# HF 캐시 — 호스트에 영속화 (재시작해도 가중치 보존). 빈 칸이면 ./.hf_cache
HF_HOME_HOST=

# 옵션 — HF rate-limit 회피
HF_TOKEN=

# μ vLLM 설정 (yaml 대신 환경변수로 override)
# 1.5B Full FT 기준 — μ도 1.5B (π와 동일 architecture, frozen base)
# 7B로 갈 거면 MU_MODEL_ID=Qwen/Qwen2.5-Math-7B-Instruct, MU_GPU_MEM=0.65
MU_MODEL_ID=Qwen/Qwen2.5-Math-1.5B-Instruct
MU_GPU_MEM=0.25        # 24GB GPU → 0.25*24 = 6 GB (1.5B bf16 ~3GB + KV cache 충분)
MU_MAX_LEN=4096        # default 32k는 24GB GPU에서 OOM
